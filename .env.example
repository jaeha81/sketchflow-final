# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI Provider (Legacy 단일 프로바이더): claude | openai | gemini
# 캐스케이드 폴백을 사용할 경우 AI_PROVIDER_CHAIN 을 우선 사용합니다.
AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# 무료 기반 캐스케이드 프로바이더 키
# Gemini: https://aistudio.google.com/apikey 에서 무료 발급
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter: https://openrouter.ai/keys 에서 무료 발급 (free 모델 한정)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Groq: https://console.groq.com/keys 에서 무료 발급
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# App
NEXT_PUBLIC_APP_NAME=SketchFlow
NEXT_PUBLIC_APP_URL=http://localhost:3000
