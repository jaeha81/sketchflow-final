# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI Provider 캐스케이드 폴백 체인 (콤마 구분, 왼쪽부터 순차 시도)
# 각 프로바이더는 AI_PROVIDER_TIMEOUT_MS 시간 안에 응답해야 하며 실패 시 다음으로 자동 전환됩니다.
AI_PROVIDER_CHAIN=gemini,openrouter,groq
AI_PROVIDER_TIMEOUT_MS=20000

# Legacy 단일 프로바이더 (AI_PROVIDER_CHAIN 미설정 시 사용): claude | gemini | openrouter | groq
AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# 무료 기반 캐스케이드 프로바이더 키
# Gemini: https://aistudio.google.com/apikey 에서 무료 발급
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter: https://openrouter.ai/keys 에서 무료 발급 (free 모델 한정)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Groq: https://console.groq.com/keys 에서 무료 발급
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# App
NEXT_PUBLIC_APP_NAME=SketchFlow
NEXT_PUBLIC_APP_URL=http://localhost:3000
